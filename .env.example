CERULEAN_HTTP_ADDR=:8080
CERULEAN_CORS_ORIGINS=http://localhost:5173

# Object storage. MVP defaults to local filesystem; switch to MinIO adapter later.
CERULEAN_STORAGE_DRIVER=local
CERULEAN_LOCAL_STORAGE_DIR=.var/objects
CERULEAN_MINIO_ENDPOINT=localhost:9000
CERULEAN_MINIO_ACCESS_KEY=minioadmin
CERULEAN_MINIO_SECRET_KEY=minioadmin
CERULEAN_MINIO_BUCKET=cerulean-papers
CERULEAN_MINIO_USE_SSL=false

# Search backends
CERULEAN_ELASTIC_URL=http://localhost:9200
CERULEAN_ELASTIC_INDEX=cerulean_chunks
CERULEAN_AMARANTH_URL=http://localhost:9090
CERULEAN_AMARANTH_COLLECTION=papers

# Optional LLM endpoint. Keep empty for mock answer mode.
CERULEAN_LLM_BASE_URL=http://localhost:3860/v1
CERULEAN_LLM_MODEL=qwen3
